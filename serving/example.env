# Copy this file to serving/.env and fill in your credentials.
# The serving containers run inside Docker, so they reach the ClearML server
# running on the host through host.docker.internal (API/Web). The files server
# uses the clearml-files alias so the same artifact URL works on host and in the
# containers (see README section 4.0).

CLEARML_WEB_HOST="http://host.docker.internal:8080"
CLEARML_API_HOST="http://host.docker.internal:8008"
CLEARML_FILES_HOST="http://clearml-files:8081"

CLEARML_API_ACCESS_KEY="<your_access_key>"
CLEARML_API_SECRET_KEY="<your_secret_key>"

# Filled after running: clearml-serving create --name "itmo-sentiment-serving"
CLEARML_SERVING_TASK_ID=""

# Must match the scikit-learn version used during training (model pickle is
# version-sensitive), and stay numpy-1.x compatible for the serving image.
CLEARML_EXTRA_PYTHON_PACKAGES="scikit-learn==1.4.2"
