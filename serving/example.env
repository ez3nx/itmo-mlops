# Copy this file to serving/.env and fill in your credentials.
# The serving containers run inside Docker, so they reach the ClearML server
# running on the host through host.docker.internal (not localhost).

CLEARML_WEB_HOST="http://host.docker.internal:8080"
CLEARML_API_HOST="http://host.docker.internal:8008"
CLEARML_FILES_HOST="http://host.docker.internal:8081"

CLEARML_API_ACCESS_KEY="<your_access_key>"
CLEARML_API_SECRET_KEY="<your_secret_key>"

# Filled after running: clearml-serving create --name "itmo-sentiment-serving"
CLEARML_SERVING_TASK_ID=""

# Packages installed inside the inference container for the custom engine.
CLEARML_EXTRA_PYTHON_PACKAGES="scikit-learn scipy numpy"
